---
import { getCollection } from "astro:content";
const { title, url, description, pubDate, tags } = Astro.props;
---

<li class="grid grid-cols-[9.5ch_1fr] gap-6 items-center">
    <div class="italic text-sm">
        {
            pubDate.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
            })
        }
    </div>
    <div>
        <a
            class="transition text-foreground font-medium hover:underline inline"
            href={url}>{title}</a
        >
    </div>
</li>
